DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRY_HOURS=720
# Comma-separated origins. For local React dev: http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=false
DB_POOL_MIN=2
DB_POOL_MAX=10
# SMTP for magic link emails (leave SMTP_HOST empty to log links instead of emailing)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@snippets.eu
# Base URL for magic link (the frontend domain)
MAGIC_LINK_BASE_URL=https://web.snippets.eu
# Anthropic API key for AI-powered Anki flashcard export
ANTHROPIC_API_KEY=
