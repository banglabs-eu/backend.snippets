# Selects which .env.{APP_ENV} file main.py loads. Default: dev.
APP_ENV=dev

DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRY_HOURS=720
# Comma-separated origins. snippets.eu is canonical; web.snippets.eu kept during the
# CNAME transition; snippets.bang-labs.eu mirrors snippets.eu's content directly (see
# nginx.prod.conf) so it needs its own CORS entry for the SPA's client-side fetches.
# For local React dev, add http://localhost:5173,http://localhost:3000.
ALLOWED_ORIGINS=https://snippets.eu,https://web.snippets.eu,https://snippets.bang-labs.eu,https://news.snippets.eu
DEBUG=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# Username allowed to mint invite codes via POST /invite-codes. Default: adam.
INVITE_ADMIN=adam

# Google OAuth — get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Magic-link sign-in
# Base URL of the frontend; the verify token is appended as ?token=...
# In production set this to https://snippets.eu (canonical).
MAGIC_LINK_BASE_URL=http://localhost:5173
MAGIC_LINK_TTL_MINUTES=10

# SMTP for outbound mail (magic links). Leave SMTP_HOST empty to log links to stdout instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

# public.snippets (Next.js) webhook — pings its /api/revalidate on publish/unpublish/edit/delete
# so ISR caches drop immediately instead of waiting out their revalidate window. Must match
# that app's REVALIDATE_SECRET exactly. Leaving this unset disables the webhook (no-op, not an error).
PUBLIC_SITE_URL=http://127.0.0.1:3000
PUBLIC_SITE_REVALIDATE_SECRET=
